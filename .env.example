# Ollama model names — run `ollama list` to see what's available locally
RAG_MODEL=gemma3:4b
BRIEFING_MODEL=gemma3:4b
EMBED_MODEL=nomic-embed-text
RERANK_MODEL=gemma3:4b

# ChromaDB collection name (change to start fresh with a new collection)
CHROMA_COLLECTION=workspace_memory

# Ollama server endpoint (default: local)
OLLAMA_HOST=http://localhost:11434

# Set to false to disable all Google Workspace integration
ENABLE_GOOGLE=true

# Search pipeline tuning
BM25_TOP_K=20
RERANK_TOP_K=3
VECTOR_TOP_K=10
YOUTUBE_MAX_TRANSCRIPT_CHARS=50000
